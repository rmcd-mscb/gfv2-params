#!/bin/bash
#SBATCH -p cpu
#SBATCH -A impd
#SBATCH --job-name=proc_prism
#SBATCH --output=logs/job_%A_%a.out
#SBATCH --error=logs/job_%A_%a.err
#SBATCH --time=01:00:00        # Adjust as needed
#SBATCH --ntasks=1             # Single task per job
#SBATCH --cpus-per-task=2      # Adjust based on your script's CPU usage
#SBATCH --mem=128G              # Adjust based on memory needs

# Load required modules
module load miniforge/latest
conda activate geoenv

python /caldera/hovenweep/projects/usgs/water/impd/nhgf/gfv2_param/gfv2-params/scripts/8_add_nat_hru_id_default_nhru.py \
--dict /caldera/hovenweep/projects/usgs/water/impd/nhgf/gfv2_param/nhm_params/paramdb_dict/paramDB_DataDictionary_07_16_2025.csv \
--base_dir /caldera/hovenweep/projects/usgs/water/impd/nhgf/gfv2_param/nhm_params/default \
--output_dir /caldera/hovenweep/projects/usgs/water/impd/nhgf/gfv2_param/nhm_params/nhm_default_params_merged
