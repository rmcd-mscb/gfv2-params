#!/bin/bash
#SBATCH -p cpu
#SBATCH -A impd
#SBATCH --job-name=download_nhm_v11
#SBATCH --output=logs/job_%j.out
#SBATCH --error=logs/job_%j.err
#SBATCH --time=04:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=8G

module load miniforge/latest
conda activate geoenv

cd $SLURM_SUBMIT_DIR
python -m gfv2_params.download.nhm_v11_lulc
